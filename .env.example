# Qovira application environment variables.
# Copy this file to .env (never commit .env) and adjust as needed.

# TCP address the HTTP server listens on.
# Default: :18888
QOVIRA_ADDR=:18888

# Minimum log level emitted by the slog JSON logger.
# One of: debug, info, warn, error
# Default: info
QOVIRA_LOG_LEVEL=info

# Log output format.
# One of: json, text
# Default: json
QOVIRA_LOG_FORMAT=json
