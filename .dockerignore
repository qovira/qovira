# Version control
.git
.github

# Documentation (not needed in build context)
*.md
LICENSE

# Go build output — the Dockerfile builds the binary inside the container
/qovira
/dist/
/vendor/
*.test
*.out

# Environment and secrets — never in the build context
.env
.env.*

# Local data and databases
/data/
*.db
*.db-wal
*.db-shm
*.db-journal
*.sqlite
*.sqlite3

# Editor and OS artefacts
.DS_Store
Thumbs.db
*.swp
*.swo
*~
.idea/
.vscode/

# Test / profiling output
coverage.out
coverage.html
*.prof
cpu.out
mem.out

# Linter cache
.golangci-lint/

# NOTE: internal/httpx/webdist/ is intentionally NOT excluded.
# The Go build stage receives the directory empty (it is gitignored and therefore
# absent after `COPY . .`); the Dockerfile's `COPY --from=web /web/build/ ./internal/httpx/webdist/`
# step populates it from the web stage before `go build -tags embed_spa` runs.

# Exclude local web/ artefacts that must not pollute the Docker build context.
# node_modules/ is installed fresh inside the node builder stage — copying local
# ones would corrupt the installed tree (pnpm detects the mismatch and aborts).
# build/ and .svelte-kit/ are generated inside the node stage; they are not
# needed from the host and would shadow the real build outputs.
web/node_modules/
web/build/
web/.svelte-kit/
web/storybook-static/
