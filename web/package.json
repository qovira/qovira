{
  "name": "qovira-web",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "prepare": "svelte-kit sync",
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "compile:i18n": "paraglide-js compile --project ./project.inlang --outdir ./src/lib/paraglide",
    "check": "pnpm compile:i18n && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "pnpm compile:i18n && eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "generate:api": "openapi-typescript ../openapi.yaml -o src/lib/api/schema.d.ts",
    "test": "pnpm compile:i18n && vitest run",
    "test:unit": "pnpm compile:i18n && vitest run --project node --project runes --project jsdom --project browser",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "test:storybook": "pnpm compile:i18n && vitest run --project storybook",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "@internationalized/date": "^3.8.0",
    "@qovira/theme": "^2.1.0",
    "@qovira/ui": "^2.1.0",
    "dompurify": "^3.4.10",
    "marked": "^18.0.5",
    "openapi-fetch": "0.17.0",
    "phosphor-svelte": "^3.1.0",
    "svelte": "^5.56.0",
    "ulid": "^3.0.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@inlang/paraglide-js": "^2.19.0",
    "@inlang/plugin-message-format": "^4.4.0",
    "@storybook/addon-a11y": "^10.4.4",
    "@storybook/addon-docs": "^10.4.4",
    "@storybook/addon-svelte-csf": "^5.1.2",
    "@storybook/addon-vitest": "^10.4.4",
    "@storybook/sveltekit": "^10.4.4",
    "@sveltejs/adapter-static": "^3.0.0",
    "@sveltejs/kit": "^2.64.0",
    "@sveltejs/vite-plugin-svelte": "^7.1.0",
    "@tailwindcss/vite": "^4.3.0",
    "@types/jsdom": "^28.0.3",
    "@types/node": "^25.9.3",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/browser-playwright": "^4.1.8",
    "eslint": "^9.0.0",
    "eslint-plugin-svelte": "^2.46.0",
    "globals": "^15.0.0",
    "happy-dom": "^20.10.3",
    "jsdom": "^29.1.1",
    "openapi-typescript": "7.13.0",
    "@playwright/test": "1.60.0",
    "playwright": "1.60.0",
    "prettier": "^3.0.0",
    "prettier-plugin-svelte": "^3.0.0",
    "storybook": "^10.4.4",
    "svelte-check": "^4.6.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.0",
    "typescript-eslint": "^8.0.0",
    "vite": "^8.0.0",
    "vitest": "^4.1.0"
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@11.3.0"
}
